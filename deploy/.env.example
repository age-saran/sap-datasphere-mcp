# ============================================================
# SAP Datasphere MCP Server — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# --- Transport --------------------------------------------------
MCP_TRANSPORT=http
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8080
MCP_HTTP_PATH=/mcp

# Bearer token for all HTTP endpoints (MCP + REST).
# Generate a strong random token: python3 -c "import secrets; print(secrets.token_hex(32))"
MCP_HTTP_AUTH_TOKEN=CHANGE_ME_generate_a_strong_token_here

# Public URL (used in OpenAPI spec's servers[] field)
# Set to your Cloudflare Tunnel domain once you know it
MCP_PUBLIC_URL=https://YOUR-TUNNEL.trycloudflare.com

# --- SAP Datasphere ---------------------------------------------
USE_MOCK_DATA=false
DATASPHERE_BASE_URL=https://YOUR-TENANT.eu10.hcs.cloud.sap
DATASPHERE_TENANT_ID=YOUR_TENANT_ID

# OAuth2 Client Credentials
DATASPHERE_CLIENT_ID=YOUR_CLIENT_ID
DATASPHERE_CLIENT_SECRET=YOUR_CLIENT_SECRET
DATASPHERE_TOKEN_URL=https://YOUR-TENANT.authentication.eu10.hana.ondemand.com/oauth/token
DATASPHERE_OAUTH_SCOPE=

# --- Logging ----------------------------------------------------
LOG_LEVEL=INFO
